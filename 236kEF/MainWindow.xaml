<Window x:Class="_236kEF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_236kEF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Background="Aqua">
            <TextBlock Text="КОЛЛЕДЖ БД" FontSize="30"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Background="CadetBlue">
            <Button Content="Группы" Width="150" Margin="10" Click="Group_Click"/>
            <Button Content="Студенты" Width="150" Margin="10" Click="Student_Click"/>
            <Button Content="Выход" Width="150" Margin="10" Click="Button_Click"/>
            <TextBox x:Name="www" />

            <TextBlock x:Name="txtName" Foreground="White"/>
            <TextBlock x:Name="txtRole" Foreground="White"/>
        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Row="1" Grid.Column="1"/>

    </Grid>
</Window>
