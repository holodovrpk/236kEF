<Window x:Class="_236kEF.AddGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_236kEF"
        mc:Ignorable="d"
        Title="AddGroupWindow" Height="250" Width="500">
    <StackPanel Width="300">
        <TextBlock Text="Группа" />
        <TextBox Text="{Binding Name}" />
        <TextBlock Text="Куратор" />
        <TextBox Text="{Binding Curator}" />
        <TextBlock Text="Курс" />
        <TextBox Text="{Binding Course}" />
        <Button Content="Добавить" Click="Add_Click"/>
    </StackPanel>
</Window>
