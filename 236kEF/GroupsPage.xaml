<Page x:Class="_236kEF.GroupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_236kEF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GroupsPage">

    <StackPanel>
        <StackPanel Orientation="Horizontal" >
            <TextBlock Text="Группы" FontSize="16" Width="500"/>
            <Button Content="🂐" Click="Plitka_Click" Margin="2"/>
            <Button Content="📔" Click="Table_Click" Margin="2"/>
        </StackPanel>
        

        <DataGrid x:Name="GroupTable" AutoGenerateColumns="True" Visibility="Collapsed"
                  CanUserAddRows="False"
                  />

        <ScrollViewer Height="250">
            <ItemsControl x:Name="GroupItem" Width="550" >
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Background="Aquamarine" Margin="5">
                            <TextBlock Text="{Binding Name}" FontSize="30" FontWeight="ExtraBold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Curator, StringFormat=Куратор: {0}}" FontSize="20" Width="400"/>
                                <TextBlock Text="{Binding Course, StringFormat=Курс: {0}}" FontSize="20"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="🗑️" Margin="5" Click="Del_Click"/>
                                <Button Content="✏️" Margin="5" Click="Edit_Click"/>
                            </StackPanel>
                        </StackPanel>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>


        <Button Content="Добавить группу" Click="Add_Click"/>
        <Button Content="Сохранить изменения" Click="Save_Click"/>
    </StackPanel>
</Page>
